{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "./dist",
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/server.ts", "src/routes/**/*", "src/controllers/**/*", "src/models/**/*", "src/services/**/*", "src/middleware/**/*", "src/config/**/*", "src/lib/**/*"]
}
