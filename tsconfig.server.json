{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "isolatedModules": false,
    "noEmit": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "ignoreDeprecations": "5.0",
    "rootDir": "."
  },
  "include": [
    "src/server.ts",
    "src/routes/**/*",
    "src/controllers/**/*",
    "src/services/**/*",
    "src/models/**/*",
    "src/middleware/**/*",
    "src/utils/**/*",
    "src/config/**/*",
    "src/lib/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "src/app/**/*",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/contexts/**/*"
  ]
}